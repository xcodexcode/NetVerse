rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function sameOwnerOnWrite() {
      return request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create, read, update: if isOwner(userId);
      allow delete: if false;
    }

    match /userSettings/{userId} {
      allow create, read, update, delete: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow create: if isSignedIn() && sameOwnerOnWrite();
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid
        && (!("userId" in request.resource.data) || sameOwnerOnWrite());
    }

    match /labProgress/{progressId} {
      allow create: if isSignedIn() && sameOwnerOnWrite();
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid
        && (!("userId" in request.resource.data) || sameOwnerOnWrite());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
